JWT_SECRET=replace-with-a-long-random-string   # e.g. openssl rand -hex 32
PORT=3001
NODE_ENV=development

# Anthropic — server-side only, NEVER use VITE_ prefix for this key
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# HubSpot OAuth — create a Private App at https://developers.hubspot.com
HUBSPOT_CLIENT_ID=your_client_id_here
HUBSPOT_CLIENT_SECRET=your_client_secret_here
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/hubspot/callback

# Production URL(s) — used for CORS. Comma-separated for multiple domains.
# In production set this to your Railway/Render/etc URL, e.g.:
#   APP_URL=https://shiphero-dashboard.up.railway.app
# Or if you add a custom domain later:
#   APP_URL=https://shiphero-dashboard.up.railway.app,https://qbr.shiphero.com
APP_URL=http://localhost:5173
